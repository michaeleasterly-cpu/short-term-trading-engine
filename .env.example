# ─── Alpaca (paper-trading defaults; swap for live keys when graduating) ───
# Two naming conventions exist for historical reasons — code reads either pair:
#   ALPACA_KEY/ALPACA_SECRET (current production env)
#   ALPACA_API_KEY/ALPACA_API_SECRET (legacy)
ALPACA_KEY=
ALPACA_SECRET=
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_URL=https://data.alpaca.markets
# Set to "true" to confirm paper-trading mode (defensive — code checks this).
ALPACA_PAPER=true
# Endpoint hint (informational; some adapters read this).
ALPACA_ENDPOINT=paper

# Optional — live-account credentials. Populated only after an engine clears
# the credibility gate AND has accrued ≥ 30 paper trades on the live tape.
# ALPACA_LIVE_KEY=
# ALPACA_LIVE_SECRET=

# ─── Data providers ───
# Financial Modeling Prep ($22/mo Starter tier — fundamentals + earnings).
FMP_API_KEY=

# Tradier — DEPRECATED. The streaming-quote feed used to populate
# spread_observations was retired 2026-05-12; tier costs now derived
# from the Corwin-Schultz bootstrap on prices_daily. Keys still read by
# legacy code paths if present.
# TRADIER_TOKEN=
# TRADIER_PRODUCTION_TOKEN=

# ─── Postgres ───
# Supabase has TWO connection URLs and the choice matters:
#   DATABASE_URL_IPV4 — pooler (aws-1-us-east-1.pooler.supabase.com:5432).
#                       Use locally on macOS; supports concurrent connections
#                       but enforces a statement timeout (~30s).
#   DATABASE_URL_IPV6 — direct (db.<project>.supabase.co:5432). No timeout but
#                       requires ipv6EgressEnabled service config on Railway.
# Set both, then export DATABASE_URL=$DATABASE_URL_IPV4 at runtime locally.
DATABASE_URL=postgresql+asyncpg://ste:ste@localhost:5432/ste
DATABASE_URL_IPV4=
DATABASE_URL_IPV6=

# ─── Process behaviour ───
# Forced UTC for all process timestamps.
TZ=UTC

# Optional capital configuration (defaults applied if absent):
# PLATFORM_CAPITAL=10000        # total platform capital in USD
# SIGMA_ENGINE_EQUITY=2500      # per-engine sub-account
# REVERSION_ENGINE_EQUITY=2500
# VECTOR_ENGINE_EQUITY=2500

# Optional feature toggles:
RISK_KILL_SWITCH=false
# ALLOW_SHORTS=false             # block short orders even if the engine asks
# ENABLE_PARITY_HARNESS=false    # write live-vs-paper drift to platform.parity_drift_log

# Optional test-suite toggles:
# RUN_DB_INTEGRATION_TESTS=false # exercise real Postgres in pytest
# RUN_FMP_LIVE_TESTS=false       # hit real FMP API in pytest

# Optional commit-tracking (Railway injects automatically; set manually if
# running locally and you want the audit row to carry the commit SHA):
# RAILWAY_GIT_COMMIT_SHA=
# GIT_COMMIT_SHA=
