.ruff_cache/

# Lab dossier run artifacts (ops/lab/dossier.py emits
# docs/lab/{day}-{candidate}-{verdict}-seed{seed}.{md,json} per run —
# these are RUN ARTIFACTS, not source; the tracked docs/lab/.gitkeep is
# unaffected by these path-specific patterns).
docs/lab/*-seed*.md
docs/lab/*-seed*.json

# Data / local artifacts
*.db
*.sqlite3
# Data is NEVER tracked in git (operator directive 2026-05-23: "dont put the csvs
# on the github... take them completely out... i'm not sharing that work").
# Leading slash = top-level `data/` only — DOES NOT match `tpcore/data/` etc.
/data/
!/data/.gitkeep
/data/raw/
/data/cache/
/data/tradier_export/
/data/alpaca_backfill/
/data/fmp_backfill/
/data/corp_actions_backfill/
/data/sec_backfill/
/data/*_archive/
/data/db_snapshots/
/data/fred_macro_backfill/
/data/hy_spread_recovery/
/data/sentinel_activation_probe/
/data/tsp_entrepreneur_import/
logs/
backtests/

# Claude Code extension surface — local-only state (worktrees /
# project session caches / machine-specific permissions / dotfiles) is
# ignored; the version-controlled architecture surface (rules / skills
# / agents / hooks / project settings.json) is explicitly un-ignored.
#
# Skills are narrowly whitelisted: only the project-authored skill
# dirs are tracked. Plugin-installed skills (Supabase, Vercel, etc.)
# are copied/linked into .claude/skills/ at install time and must NOT
# enter version control (they belong to the user's plugin install).
.claude/*
!.claude/rules/
!.claude/agents/
!.claude/hooks/
!.claude/settings.json
!.claude/skills/
!.claude/path_registry.yaml
.claude/skills/*
!.claude/skills/engine-readiness/
!.claude/skills/adapter-readiness/
!.claude/skills/lab-target-run/
!.claude/skills/ecr/
!.claude/skills/dfcr/
!.claude/skills/audit-data-pipeline/
!.claude/skills/run-data-ops/
!.claude/skills/weekly-digest/
!.claude/skills/defect-register/
!.claude/skills/security-review/
!.claude/skills/commit/
!.claude/skills/commit-push-pr/
!.claude/skills/clean-gone/

# C0.5 — Claude session/cost reports are operator-local artifacts:
# generated by ``scripts/claude_session_report.py``, gitignored so
# no metadata report (and especially no redacted-secret report)
# ever enters version control. The pattern globs are defense in
# depth — an ``--output-dir .`` invocation still cannot leak the
# report past these rules.
.operator/reports/claude/
claude-session-report*.json
claude-session-report*.md
claude-session-report*.html
!.claude/skills/lab-spec-emit/
!.claude/skills/lab-edge-find/
!.claude/skills/triage-data-failures/
!.claude/skills/triage-engine-failures/

# Publishing — `python -m build` artifacts are operator-local; the
# carved `publishing/stelib/stelib/` Python source IS tracked.
publishing/stelib/dist/
publishing/stelib/build/
publishing/stelib/*.egg-info/

# P2a (2026-05-30) — SEC submissions cache. Operator-local bulk-file
# cache for the ``_stage_backfill_sec_lifecycle`` stage; the on-disk
# ``CIK<padded>.json`` files mirror SEC's URL shape so they are self-
# describing. ~1.3 GB for the full delisted+inactive cohort; never
# committed. TP_DATA_DIR override is supported.
data/sec_submissions/
